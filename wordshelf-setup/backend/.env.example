# ── WordShelf Backend Environment Variables ──
# Copy to .env and fill in real values
# NEVER commit .env to git

# ── App ──
APP_NAME=WordShelf
DEBUG=True
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Database (MySQL) ──
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/wordshelf_db

# ── Database (MongoDB — use this instead if choosing MongoDB) ──
# MONGO_URI=mongodb://localhost:27017/wordshelf

# ── JWT ──
JWT_SECRET_KEY=another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── External APIs ──
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key
# OR use LibreTranslate (free, no key needed for local):
LIBRETRANSLATE_URL=https://libretranslate.com

# ── Free Dictionary API (no key needed) ──
DICTIONARY_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en

# ── Email (for password reset) ──
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Upload ──
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=5242880   # 5MB
